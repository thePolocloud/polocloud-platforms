{
  "name": "waterfall",
  "type": "PROXY",
  "language": "JAVA",
  "globalArgs": [],
  "tasks": [],
  "versionDetection": {
    "mode": "AUTOMATIC",
    "baseUrl": "https://fill.papermc.io/v3/projects/waterfall",
    "parse": {
      "type": "JSON",
      "versionPath": "versions",
      "buildUrl": "{baseUrl}/versions/{version}/builds",
      "buildPath": "[0].id",
      "downloadPath": "[0].downloads[\"server:default\"].url"
    }
  }
}
