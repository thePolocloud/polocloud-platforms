{
  "name": "folia",
  "type": "SERVER",
  "language": "JAVA",
  "globalArgs": ["--nogui"],
  "tasks": [],
  "versionDetection": {
    "mode": "AUTOMATIC",
    "baseUrl": "https://fill.papermc.io/v3/projects/folia",
    "parse": {
      "type": "JSON",
      "versionPath": "versions",
      "buildUrl": "{baseUrl}/versions/{version}/builds",
      "buildPath": "[0].id",
      "downloadPath": "[0].downloads[\"server:default\"].url"
    }
  }
}
