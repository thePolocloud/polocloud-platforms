{
  "key": "server_properties",
  "steps": [
    {
      "name": "Setup port for spigot based server",
      "file": "server.properties",
      "type": "REPLACE",
      "key": "server-port",
      "value": "%server_port%"
    },
    {
      "name": "Setup query port for spigot based server",
      "file": "server.properties",
      "type": "REPLACE",
      "key": "query.port",
      "value": "%server_port%"
    }
  ]
}